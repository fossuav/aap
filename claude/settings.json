{
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(./waf:*)",
      "Bash(python3 Tools/autotest/autotest.py:*)",
      "Bash(Tools/autotest/sim_vehicle.py:*)",
      "Bash(python3 .claude/skills/autotest/run_autotest.py:*)",
      "Bash(python3 .claude/skills/autotest/autotest_results.py:*)",
      "Bash(python3 .claude/skills/log-analyze/log_extract.py:*)",
      "Bash(python3 .claude/skills/log-analyze/flow_cal_check.py:*)",
      "Bash(python3 .claude/skills/pr-checks/ci_failures.py:*)",
      "Bash(python3 .claude/skills/hwdef-check/hwdef_check.py:*)",
      "Bash(astyle:*)",
      "Bash(luacheck:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(mkdir:*)",
      "Bash(mktemp:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash_check.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_edit_check.py\""
          }
        ]
      }
    ]
  }
}
