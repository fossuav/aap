{
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip3 show:*)",
      "Bash(timeout:*)",
      "Bash(./waf:*)",
      "Bash(Tools/autotest/autotest.py:*)",
      "Bash(Tools/autotest/sim_vehicle.py:*)",
      "Bash(mavlogdump.py:*)",
      "Bash(mavproxy.py:*)",
      "Bash(astyle:*)",
      "Bash(luacheck:*)",
      "Bash(git:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh auth status:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(mktemp:*)",
      "Bash(rm -f /tmp/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash_check.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_edit_check.py\""
          }
        ]
      }
    ]
  }
}
